DirectoryIndex index.html
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^go/tg/?$ https://t.me/tolstuil [R=302,L,NE]
  RewriteRule ^go/portfolio/?$ https://alexeyzharkov.ru/?utm_source=zh.ru.net&utm_medium=referral&utm_campaign=personal_hub [R=302,L,NE]
  RewriteRule ^go/product/?$ https://xn----7sbzclracelfoe2a.xn--p1ai/?utm_source=zh.ru.net&utm_medium=referral&utm_campaign=personal_hub [R=302,L,NE]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"

  <FilesMatch "\.(css|js|svg)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  <FilesMatch "\.(xml|txt)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  <Files "index.html">
    Header set Cache-Control "no-cache, max-age=0, must-revalidate"
  </Files>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
  ExpiresByType text/plain "access plus 1 day"
</IfModule>
